# Theme
theme = rose-pine-moon

# Font
font-size = 17
font-family = JetBrainsMono Nerd Font

# Cursor
cursor-style = block
cursor-style-blink = false

# window
resize-overlay = never
background = 000000
background-opacity = 1
background-blur = false
window-step-resize = false
window-padding-balance = true
confirm-close-surface = false

# clipboard
clipboard-trim-trailing-spaces = true
copy-on-select = clipboard

# Ghostty notifications
app-notifications = no-clipboard-copy

# behavior
auto-update = check
auto-update-channel = stable
quit-after-last-window-closed = true
shell-integration-features = no-cursor,no-sudo,no-title
gtk-titlebar = false

# Macos
# macos-titlebar-style = hidden
# macos-option-as-alt = true

# For Simple Keybinds
keybind = alt+b>i=inspector:toggle
keybind = alt+b>t=toggle_quick_terminal

keybind = alt+b>q=close_surface

# this only works if you have `macos-titlebar-style = tabs or native or transparent`
# else it behaves like new window
keybind = alt+b>d=new_tab

# tab nav
keybind = alt+1=goto_tab:1
keybind = alt+2=goto_tab:2
keybind = alt+3=goto_tab:3
keybind = alt+4=goto_tab:4
keybind = alt+5=goto_tab:5
keybind = alt+6=goto_tab:6
keybind = alt+7=goto_tab:7
keybind = alt+8=goto_tab:8
keybind = alt+9=goto_tab:9
keybind = alt+0=goto_tab:10

# splitting
keybind = alt+b>h=new_split:left
keybind = alt+b>j=new_split:down
keybind = alt+b>k=new_split:up
keybind = alt+b>l=new_split:right
keybind = alt+b>e=equalize_splits

# split nav (setting this to control will not work if tmux already uses it)
keybind = alt+h=goto_split:left
keybind = alt+j=goto_split:bottom
keybind = alt+k=goto_split:top
keybind = alt+l=goto_split:right

keybind = alt+b>c=reload_config

#Shaders
# custom-shader = shaders/bettercrt.glsl
# custom-shader = shaders/retro-terminal.glsl
